@model IEnumerable<PhoneShop.Models.Product>
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>
    <h1>Product List</h1>
    <table>
        <thead>
             <tr>
				<th>@Html.DisplayNameFor(m => m.Id)</th>
                <th>@Html.DisplayNameFor(m => m.Name)</th>
                <th>@Html.DisplayNameFor(m => m.Price)</th>
                <th>@Html.DisplayNameFor(m => m.PriceSale)</th>
                <th>@Html.DisplayNameFor(m => m.Category!.Name)</th>
                <th>@Html.DisplayNameFor(m => m.Photo)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(m => item.Id)</td>
                        <td>@Html.DisplayFor(m => item.Name)</td>
                        <td>@Html.DisplayFor(m => item.Price)</td>
                        <td>@Html.DisplayFor(m => item.PriceSale)</td>
                        <td>@Html.DisplayFor(m => item.Category!.Name)</td>
                        <td>@Html.DisplayFor(m => item.Photo)</td>
                    </tr>
                }
            </tbody>
</table>
</body>
</html>
